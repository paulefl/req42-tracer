        Component(system_cli_init, "Init Command", "Go", "Initializes new req42+arc42 project with templates")
        Component(system_cli_lsp, "LSP Command", "Go", "Starts LSP server on stdio")
        Component(system_cli_trace, "Trace Command", "Go", "Runs traceability analysis and produces matrix report")
        Component(system_cli_validate, "Validate Command", "Go", "Validates project structure and cross-references")
        Component(system_cli_watch, "Watch Command", "Go", "File watcher with live-reload HTML report server")
