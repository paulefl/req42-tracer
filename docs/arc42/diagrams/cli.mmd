    Component(system_backend_parser, "Document Parser", "Go", "Parses AsciiDoc files and Bausteinsicht JSONC models")
    Container_Boundary(system_cli, "CLI") {
        Component(system_cli_aspice, "ASPICE Command", "Go", "Validates ASPICE PAM 4.0 compliance")
